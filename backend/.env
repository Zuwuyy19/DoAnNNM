# ================================================
# Cấu hình môi trường Backend - DevMaster
# ================================================

# Port chạy server (mặc định: 5000)
PORT=4000

# Chuỗi kết nối MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/online_course_db

# Secret key để ký JWT token
ACCESS_TOKEN_SECRET=supersecret123

# Thời gian hết hạn token (7 ngày)
JWT_EXPIRES=7d

# Frontend URL (CORS)
CLIENT_URL=http://localhost:5173